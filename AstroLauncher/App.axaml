<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AstroLauncher.App"
             Name="Astro Launcher"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        
        <StyleInclude Source="Styles/ButtonStyles.axaml"/>
        <StyleInclude Source="Styles/TextBoxStyles.axaml"/>
        <StyleInclude Source="Styles/OtherStyles.axaml"/>
    </Application.Styles>
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Colors.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        
        <FontFamily x:Key="MinecraftFont">avares://AstroLauncher/Assets/Fonts#Minecraft</FontFamily>
    </Application.Resources>
</Application>