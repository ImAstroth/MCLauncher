<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AccentColor">#8C66FF</SolidColorBrush>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="SurfaceMain">#0A0E14</SolidColorBrush>
            <SolidColorBrush x:Key="SurfaceCard">#252733</SolidColorBrush>
            <SolidColorBrush x:Key="TextPrimary">White</SolidColorBrush>
            <SolidColorBrush x:Key="SurfaceSecondary">#252934</SolidColorBrush>
        </ResourceDictionary>
        
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="SurfaceMain">#F4F4F4</SolidColorBrush>
            <SolidColorBrush x:Key="SurfaceCard">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="TextPrimary">#1A1A1A</SolidColorBrush>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>