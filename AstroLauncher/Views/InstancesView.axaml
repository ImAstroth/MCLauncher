<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AstroLauncher.ViewModels"
             xmlns:viewModels="clr-namespace:AstroLauncher.ViewModels"
             x:DataType="viewModels:InstancesViewModel"
             x:CompileBindings="True"
             x:Class="AstroLauncher.Views.InstancesView">

    <Grid>
        <StackPanel Margin="15" Spacing="3">
            <TextBlock Text="Instances" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                       HorizontalAlignment="Left"/>
        
            <TextBlock Text="Manage your Minecraft installations" FontSize="15" Foreground="{DynamicResource TextSecondary}" 
                       HorizontalAlignment="Left"/>
            
            <AutoCompleteBox PlaceholderText="Search instances..." PlaceholderForeground="{DynamicResource TextSecondary}"
                             FilterMode="Contains" MinimumPrefixLength="1" Height="32" Margin="0,10,0,0"
                             BorderBrush="{DynamicResource AccentColor}" BorderThickness="1"
                             CornerRadius="5">
                
                <AutoCompleteBox.InnerLeftContent>
                    <Image Source="/Assets/Images/search-icon.png" Margin="5,0,0,0" Width="20" Height="20"/>
                </AutoCompleteBox.InnerLeftContent>
            </AutoCompleteBox>
        </StackPanel>
    </Grid>

</UserControl>