<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AstroLauncher.ViewModels"
             xmlns:settingsPageViews="clr-namespace:AstroLauncher.Views.SettingsPageViews"
             xmlns:settingsPageViewModels="clr-namespace:AstroLauncher.ViewModels.SettingsPageViewModels"
             x:DataType="vm:SettingsViewModel"
             x:Class="AstroLauncher.Views.SettingsView"
             x:CompileBindings="True"
             
             xmlns:conv="using:AstroLauncher.Utils">
    
    <Border>
       <StackPanel Margin="15" Spacing="3">
           <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                      HorizontalAlignment="Left"/>
        
           <TextBlock Text="Customize your launcher experience" FontSize="15" Foreground="{DynamicResource TextSecondary}" 
                      HorizontalAlignment="Left"/>
           
           <Grid ColumnDefinitions="175, *" Margin="0,15,0,0">
               <!-- SETTINGS TAB -->
               <Border Grid.Column="0" Classes="InnerSurface">
                   
                   <ListBox ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory}"
                            Classes="BaseListBox">
                       
                       <ListBox.ItemTemplate>
                           <DataTemplate x:DataType="vm:ViewModelBase">
                               <StackPanel Orientation="Horizontal" Spacing="12">
                                   <PathIcon Data="{Binding IconData}" Width="18" Height="18"/>
                                   <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                               </StackPanel>
                           </DataTemplate>
                       </ListBox.ItemTemplate>
                   </ListBox>
               </Border>
               
               <!-- SETTINGS MAIN AREA -->
               <Border Grid.Column="1">
                   <ContentControl Content="{Binding SelectedCategory}">
                       <ContentControl.DataTemplates>
                           <!-- General -->
                           <DataTemplate DataType="{x:Type settingsPageViewModels:GeneralViewModel}">
                               <settingsPageViews:GeneralView/>
                           </DataTemplate>
                                                        
                           <!-- Launcher -->
                           <DataTemplate DataType="{x:Type settingsPageViewModels:LauncherViewModel}">
                               <settingsPageViews:LauncherView/>
                           </DataTemplate>
                       </ContentControl.DataTemplates>
                   </ContentControl>
               </Border>
           </Grid>
       </StackPanel>
   </Border>
    
</UserControl>
